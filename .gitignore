# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────────
.venv/
